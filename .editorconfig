# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml,scss,json}]
indent_style = space
indent_size = 2

# Markdown and Quarto: a trailing double space is a hard line break, so keep it.
[*.{md,qmd}]
trim_trailing_whitespace = false

# LaTeX sources are the canonical record; leave them untouched.
[*.tex]
trim_trailing_whitespace = false
